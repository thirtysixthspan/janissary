{
  "harnesses": [
    {
      "name": "features",
      "type": "claude",
      "model": "claude-sonnet-5",
      "effort": "medium",
      "workspace": true,
      "autoApprove": true,
      "tab": { "number": 1, "group": 1 }
    },
    {
      "name": "planning",
      "type": "claude",
      "model": "claude-opus-5",
      "effort": "medium",
      "workspace": true,
      "autoApprove": true,
      "tab": { "number": 2, "group": 1 }
    }
  ],
  "monitors": [
    { "name": "assistant", "persona": "assistant", "targets": ["group:1"] }
  ],
  "files": [
    { "dock": "left", "path": "$root" }
  ],
  "editors": [
    { "path": "$root/product/backlog/features.md" }
  ],
  "notifications": [
    { "dock": "right", "focus": true }
  ],
  "layout": {
    "sidebar": { "left": 270, "right": 330 },
    "window": { "width": 1600, "height": 800 }
  }
}
