{
  "name": "janissary",
  "version": "1.0.0",
  "description": "A terminal UI shell with built-in commands and shell execution",
  "bin": {
    "janus": "./bin/janus.mjs"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "tsx src/cli.tsx",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true; npx playwright install chromium || true"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.1",
    "ink": "^7.1.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
