{
  "name": "janissary",
  "version": "1.0.0",
  "description": "A terminal UI shell with built-in commands and shell execution",
  "bin": {
    "janus": "./bin/janus.mjs"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:server": "tsc",
    "build:web": "vite build -c web/vite.config.ts",
    "clean": "rm -rf dist web/dist",
    "start": "npm run build:web && tsx src/server/main.ts",
    "start:ink": "tsx src/cli.tsx",
    "dev:web": "vite -c web/vite.config.ts",
    "dev:server": "tsx --watch src/server/main.ts",
    "dev": "npm run dev:web & npm run dev:server",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true; npx playwright install chromium || true"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.1",
    "ink": "^7.1.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
