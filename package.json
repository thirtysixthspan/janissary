{
  "name": "janissary",
  "version": "1.0.0",
  "description": "A terminal UI shell with built-in commands and shell execution",
  "bin": {
    "janus": "./bin/janus.mjs"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:server": "tsc",
    "build:web": "vite build -c web/vite.config.ts",
    "clean": "rm -rf dist web/dist",
    "start": "npm run build:web && tsx src/main.ts",
    "dev:web": "vite -c web/vite.config.ts",
    "dev:server": "tsx --watch src/main.ts",
    "dev": "npm run dev:web & npm run dev:server",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:files": "node scripts/lint-files.mjs",
    "format": "prettier --write .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true; npx playwright install chromium || true",
    "test:server": "vitest run --project server",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:client": "vitest run --project client",
    "quality": "fta src && fta web/src",
    "quality:gate": "fta src && fta web/src",
    "quality:snapshot": "fta src --json > docs/quality/baseline-server.json && fta web/src --json > docs/quality/baseline-client.json",
    "duplication": "jscpd src web/src",
    "duplication:gate": "jscpd src web/src --exit-code",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint:css": "stylelint \"web/src/**/*.css\"",
    "lint:css:fix": "stylelint \"web/src/**/*.css\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p web/tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.1",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "fta-cli": "^3.0.0",
    "globals": "^17.6.0",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "knip": "^6.21.0",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
