{
  "name": "janissary",
  "version": "1.0.0",
  "description": "A terminal UI shell with built-in commands and shell execution",
  "bin": {
    "janus": "./bin/janus.mjs"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:server": "tsc",
    "build:web": "vite build -c web/vite.config.ts",
    "clean": "rm -rf dist web/dist",
    "start": "npm run build:web && tsx src/main.ts",
    "dev:web": "vite -c web/vite.config.ts",
    "dev:server": "tsx --watch src/main.ts",
    "dev": "npm run dev:web & npm run dev:server",
    "docs:dev": "vitepress dev documentation",
    "docs:build": "vitepress build documentation",
    "docs:preview": "vitepress preview documentation",
    "test": "vitest run --project server --project client",
    "test:browser": "vitest run --project browser",
    "test:sandbox": "vitest run --project sandbox",
    "test:unsandboxed": "vitest run --project unsandboxed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:all": "npm run lint && npm run lint:css && npm run typecheck",
    "check": "npm run typecheck && npm run lint && npm run test",
    "check:full": "npm run typecheck && npm run lint && npm run test && npm run lint:css && npm run quality && npm run duplication && npm run knip",
    "lint:files": "node scripts/lint-files.mjs",
    "format": "prettier --write .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper",
    "playwright:install-chromium": "npx playwright install chromium",
    "test:server": "vitest run --project server",
    "test:watch": "vitest --project server --project client",
    "coverage": "VITEST_SKIP_INSTALL_CHECKS=1 vitest run --coverage --project server --project client",
    "test:client": "vitest run --project client",
    "quality": "fta src && fta web/src",
    "quality:gate": "fta src && fta web/src",
    "quality:snapshot": "fta src --json > fta/baseline-server.json && fta web/src --json > fta/baseline-client.json",
    "duplication": "jscpd src web/src",
    "duplication:gate": "jscpd src web/src --exit-code",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint:css": "stylelint \"web/src/**/*.css\"",
    "lint:css:fix": "stylelint \"web/src/**/*.css\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p web/tsconfig.json",
    "typecheck:diff": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/server.tsbuildinfo -p tsconfig.json && tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/web.tsbuildinfo -p web/tsconfig.json",
    "test:diff:server": "vitest run --project server --changed",
    "test:diff:web": "vitest run --project client --changed",
    "test:diff": "vitest run --changed --project server --project client",
    "lint:diff": "node scripts/lint-files.mjs",
    "check:diff": "node scripts/check-diff.mjs",
    "security": "npm run security:secrets && npm run security:deps",
    "security:secrets": "gitleaks detect --no-banner --redact",
    "security:deps": "npm audit --omit=dev",
    "security:sast": "opengrep scan --config p/javascript --config p/typescript --config p/nodejs src/ web/src/"
  },
  "keywords": [],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "overrides": {
    "@vitejs/plugin-vue": "^6.0.7"
  },
  "files": [
    "bin",
    "dist",
    "chrome-extension",
    "agent-names.json",
    "help.md"
  ],
  "type": "module",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.1",
    "@xterm/headless": "^5.5.0",
    "diff": "^9.0.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "fta-cli": "^3.0.0",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "knip": "^6.21.0",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
